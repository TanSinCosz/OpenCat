{
  "name": "opencat-typescirpt",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "node --watch --experimental-strip-types src/main.ts",
    "web": "tsx src/web-cli.ts",
    "swe": "tsx src/eval-dashboard.ts",
    "memory:dream": "tsx scripts/run-memory-dream.ts",
    "deepseek:example": "tsx src/deepseek/example.ts",
    "smoke:cache-editing:real": "tsx scripts/smoke-deepseek-anthropic-cache-editing-real.ts",
    "smoke:auto-compress:real": "tsx scripts/smoke-auto-compress-real.ts",
    "eval:swe-cache:prepare": "python scripts/load_swe_verified_dataset.py --output .opencat/evals/swe-verified-cache/dataset.jsonl --limit 5",
    "eval:swe-cache": "tsx scripts/eval-swe-verified-cache.ts",
    "eval:swe-serial": "tsx scripts/eval-swe-serial.ts",
    "test:auto-compress": "tsx --test tests/query-auto-compress.test.ts",
    "start": "node dist/main.js"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@node-rs/jieba": "^2.0.1",
    "better-sqlite3": "^12.10.0",
    "diff": "^9.0.0",
    "lru-cache": "^11.5.1",
    "openai": "^6.42.0",
    "tree-sitter-wasms": "^0.1.13",
    "tsx": "^4.22.4",
    "uuid": "^14.0.0",
    "web-tree-sitter": "^0.26.9",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
